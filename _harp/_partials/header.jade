header.header.container
  .header__intro
    h1.header__title Michael Kleyn
    p.header__affiliation SFSU
    p.header__pronoun he/him/his
    p.header__contact mbrennan3 [at] sfsu [dot] edu

    ul.header__links.list-unstyled.list-inline
      for link in public._data.about.links
        li
          a(href="#{link.url}").no-highlight
            i.fa(class="#{link.icon}" aria-hidden="true" title="#{link.title}")


    nav
      ul.header__nav.list-unstyled.list-inline
        for link in public._data.nav
          li
            a(data-scroll href="#{link.url}") #{link.title}

  .header__photo
    figure.header__photo-wrapper
      img(src="assets/img/headshot.jpg" alt="smiling man with red hair and glasses, standing in a field with mountains in the background")
      figcaption.header__quote It's time to build...one commit at a time.
