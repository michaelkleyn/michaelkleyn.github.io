footer.footer.dark
  .container
    section.blurb
      p Not all those who wander are lost.

    ul.footer__links.list-unstyled.list-inline
      for link in public._data.about.links
        li
          a(href="#{link.url}")
            i.fa(class="#{link.icon}" aria-hidden="true" title="#{link.title}")
    
